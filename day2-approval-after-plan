pipeline {
    agent any

    stages {
        stage('git clone') {
            steps {
                git branch: 'main', url: 'https://github.com/VenkataSailaja/Terraform_CICD.git'
            }
        }
         stage('init') {
            steps {
                sh 'terraform init'
            }
        }
        stage('plan') {
            steps {
                sh 'terraform plan'
            }
        }
        stage('Approval')
        {
            steps {
                input(
                    message: 'review the terraform plan and approve deployment?',
                    ok: 'Apply'
                )
            }
        }
        stage('apply') {
            steps {
                sh 'terraform apply -auto-approve'
            }
        }
    }
}
